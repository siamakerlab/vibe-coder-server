# bkit (local tool state — never commit, per global CLAUDE.md §11)
.bkit/
# Claude Code 자체 도구 상태 (ScheduleWakeup lock 등) — never commit.
.claude/

# Gradle
.gradle/
# 모듈별 build output 무시 — 단, src 트리 안의 build 패키지(예:
# server/src/main/kotlin/.../server/build/ApkFinder.kt)는 무시하지 않는다.
**/build/
!**/src/**/build/
!**/src/**/build/**
!gradle/wrapper/gradle-wrapper.jar
local.properties

# IntelliJ / Android Studio
.idea/
*.iml
.kotlin/
captures/
.cxx/

# Server runtime data (workspace, db, logs)
vibe-coder-server-data/
server/workspace/
/workspace/

# DB
*.db
*.db-journal
*.db-shm
*.db-wal

# APK / artifacts
*.apk
*.aab

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Docker PoC artifacts (개인 환경설정/빌드 컨텍스트 산출물)
docker/.env
docker/*.local.yml
docker/build-context/

# 운영자 내부 문서 — 일반 사용자에게는 README 만 공개 (v0.10.0+)
# CLAUDE.md 는 Claude Code 자동 메모리/규칙 파일이라 운영자 전용.
# docs/ 는 PDCA 산출물 (plan/design/analysis/report) 로 내부 작업 흔적.
CLAUDE.md
docs/
vibe-coder-icon.png
Screenshot_*.jpg

