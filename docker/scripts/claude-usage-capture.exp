#!/usr/bin/expect -f
# v1.70.6 — Claude Code 2.1.x TUI 의 Usage 화면 PTY capture.
#
# 배경: Claude Code 2.1.x 부터 모든 slash command 가 --print 모드에서 차단됨
# ("/status isn't available in this environment."). quota 정보는 interactive
# TUI 에서만 확인 가능.
#
# v1.70.6 변경 (Claude 2.1.158 대응):
#   - 이전엔 `/status` 입력 후 → → → 화살표 3번으로 Usage 탭 이동했는데, 2.1.158
#     에서 그 네비게이션이 깨졌다. 2.1.158 은 **`/usage` 슬래시**가 Usage 화면을
#     바로 연다 ("Current session N% used / Current week N% used / Resets …").
#     → `/usage` 직접 호출로 교체 (탭 네비게이션 제거 = 훨씬 견고).
#   - 온보딩("Select login method") 은 entrypoint 가 ~/.claude/.claude.json 의
#     hasCompletedOnboarding=true 로 사전 차단. 그래도 trust 다이얼로그가 뜰 수
#     있어, /usage 전에 Enter 1회(기본 ❯"Yes, I trust") 로 통과시킨다(프롬프트면
#     빈 줄 제출 = 무해).
#
# 매우 fragile — Claude CLI UI 가 변경되면 다시 깨질 수 있음.
#
# 사용법: claude-usage-capture.exp <cwd>
# 출력: stdout 으로 Usage 화면 raw (ANSI escape + box-drawing 포함).
#       server-side stripAnsiAndBoxChars + parseUsageOutput 이 "N% used" 추출.
# 종료 코드: 성공 0, spawn 실패 1.

set timeout 30
set cwd [lindex $argv 0]
if {$cwd eq ""} { set cwd "/workspace" }

log_user 1

if {[catch {cd $cwd} err]} {
    puts stderr "expect: cd $cwd failed: $err"
    exit 1
}

# Claude TUI spawn.
spawn -noecho claude --dangerously-skip-permissions

# init render 완료 대기.
sleep 6

# trust 다이얼로그가 떠 있으면 기본 선택(❯ "Yes, I trust this folder") 을 Enter 로 통과.
# 이미 프롬프트면 빈 줄 제출 → 무해.
send "\r"
sleep 1.5

# Usage 화면 직접 오픈 (2.1.158+). "Current session / Current week … N% used … Resets".
send "/usage\r"
sleep 5

# 'w' 키로 주간/오늘 토글 유도 (추가 redraw — 캡처 완성도).
send "w"; sleep 1.5

# 정리: 다이얼로그 닫기 + Claude 종료.
send "\x1b"      ;# Esc
sleep 0.5
send "\x04"      ;# Ctrl-D
expect {
    eof {}
    timeout { catch {close} }
}
exit 0
