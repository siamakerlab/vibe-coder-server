#!/usr/bin/env expect -f
# v1.4.0 — Claude Code 2.1.x TUI 의 Usage 탭 PTY capture.
#
# 배경: Claude Code 2.1.x 부터 모든 slash command 가 --print 모드에서 차단됨
# ("/status isn't available in this environment."). quota 정보는 interactive
# TUI 의 Usage 탭에서만 확인 가능. 본 expect 스크립트는 PTY 안에서 Claude 를
# spawn → /status 입력 → 5탭 TUI 의 Settings 탭 첫 화면 → → → → → 3번 화살표로
# Usage 탭 이동 → 화면 capture → Esc + Ctrl-D 로 종료.
#
# 매우 fragile — Claude CLI UI 가 변경되면 즉시 깨짐. server v1.4.0 의 trade-off.
#
# 사용법: claude-usage-capture.exp <cwd>
#   cwd: claude 가 spawn 될 디렉토리 (보통 SCRATCH_PROJECT 의 /workspace/__scratch__)
# 출력: stdout 으로 Usage 탭의 raw screen content. ANSI escape + box-drawing 포함.
#       server-side stripAnsiAndBoxChars + parseUsageOutput 이 정리.
# 종료 코드: 성공 0, timeout/spawn 실패 1.

set timeout 20
set cwd [lindex $argv 0]
if {$cwd eq ""} { set cwd "/workspace/__scratch__" }

# stdin/stdout 분리: TUI screen 데이터는 stdout 으로만, expect 자체 로그는 끔.
# v1.4.1 — log_file -a /dev/stderr 는 seek 에러 ("could not seek to end of file
# while opening /dev/stderr: invalid seek") 라 그냥 disable. log_user 0 만으로
# noise 충분히 제거.
log_user 0

# 디렉토리 이동 (subprocess 환경 변수 cd) — claude 가 cwd 영향 받음 (.claude/settings.json 검색 등).
if {[catch {cd $cwd} err]} {
    puts stderr "expect: cd $cwd failed: $err"
    exit 1
}

# v1.4.2 — 순수 timing 기반 시퀀스. ANSI cursor positioning 으로 단어가 분리되어
# expect 패턴 매칭이 불안정한 문제를 우회. spawn 후 정해진 시간만 sleep + 입력.
# 화면이 아직 안 그려졌어도 다음 입력이 buffer 에 쌓여 순차 처리됨.
spawn -noecho claude --dangerously-skip-permissions

# trust dialog ("Yes, I accept") 통과 — 항상 첫 화면.
sleep 3.5
send "2\r"
sleep 5.0

# /status slash command → 5탭 TUI dialog (Settings 탭 시작).
send "/status\r"
sleep 2.5

# 화살표 우 3번 → Usage 탭 (Settings → Status → Config → Usage)
send "\x1b\[C"; sleep 0.5
send "\x1b\[C"; sleep 0.5
send "\x1b\[C"; sleep 1.5

# Usage 탭 화면 render 완료. log_user 1 로 다음 incoming bytes 부터 stdout 캡처.
log_user 1

# 'w' 키 — Current week 토글로 화면 redraw 유발 (이미 그려진 화면도 다시 flush).
send "w"
sleep 1.5
send "d"
sleep 1.5
send "w"
sleep 1.5

# capture 종료, dialog 닫기 + Claude 종료.
log_user 0
send "\x1b"      ;# Esc — dialog 닫기
sleep 0.4
send "\x04"      ;# Ctrl-D
expect {
    eof {}
    timeout { catch {close} }
}
exit 0
