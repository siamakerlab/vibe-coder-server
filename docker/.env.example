# vibe-coder Docker 환경설정 템플릿.
# 사용:
#   cp docker/.env.example docker/.env
#   값을 수정한 뒤 `docker compose -f docker/compose.yml --env-file docker/.env up -d`
#
# v0.14.0 — PostgreSQL 컨테이너 추가. **VIBECODER_DB_PASSWORD 반드시 변경 후 사용.**

# ─── 이미지 / 컨테이너 ──────────────────────────────────────────────────────

# Docker Hub에서 pull 시 사용할 태그. 로컬 빌드 시에는 무관.
VIBECODER_IMAGE=siamakerlab/vibe-coder-server:latest

# PostgreSQL 이미지 (v0.14.0+). 직접 변경하지 않는 한 그대로.
VIBECODER_POSTGRES_IMAGE=postgres:17-alpine

# 호스트 UID/GID. `id -u` / `id -g` 결과를 넣으세요. 워크스페이스 권한 매칭용.
PUID=1000
PGID=1000

TZ=Asia/Seoul

# ─── 네트워크 ──────────────────────────────────────────────────────────────

# 호스트에 노출할 포트. LAN의 다른 기기에서 http://<PC IP>:이포트/ 로 접속.
VIBE_PORT=17880

# 선택 기능: 빌드환경 → "SSH 서버" 카드 설치 후 원격 접속에 사용할 포트.
# 보통은 host port 인 VIBE_SSH_PORT 만 바꾸면 됩니다(컨테이너 포트 기본 2222).
# 카드에서 컨테이너 SSH 포트까지 바꾼 경우에만 VIBECODER_SSH_PORT 를 같은 값으로
# 주석 해제하고 컨테이너를 재생성하세요.
VIBE_SSH_PORT=2222
# VIBECODER_SSH_PORT=2222

# ─── 데이터 디렉토리 (v0.7.0 통합 구조) ────────────────────────────────────
#
# 모든 영구 데이터는 이 한 디렉토리 안에 모입니다. 이 디렉토리만 백업하면
# 워크스페이스 / PostgreSQL / Android SDK / Gradle 캐시 / MCP / Playwright /
# 설정 까지 전부 보존됩니다. 이미지 업그레이드 / 컨테이너 재생성 시에도 안전.
#
# 컴퓨터 이전 (postgres 컨테이너는 정지한 채로 백업 권장):
#   docker compose stop postgres   # 데이터 일관성 보장
#   tar czf vibe-coder-data.tar.gz vibe-coder-data/
#   docker compose up -d
#
# 디렉토리 구조 (compose 가 자동 생성):
#   ./vibe-coder-data/
#     ├── workspace/      ← 프로젝트 소스 / APK
#     ├── postgres/       ← PostgreSQL 데이터 (v0.14.0+)
#     ├── server/         ← 로그 / 빌드 메타
#     ├── dev-tools/      ← Android SDK / Gradle / MCP / Playwright / Codex / OpenCode / 설정
#     └── claude/         ← Claude OAuth 자격증명 / MCP 등록 정보
#
VIBE_DATA_ROOT=./vibe-coder-data

# ─── PostgreSQL (v0.14.0+) ─────────────────────────────────────────────────
#
# **VIBECODER_DB_PASSWORD 는 반드시 강력한 값으로 변경하세요.**
# compose 가 빈 값에서 부팅 시도하면 명시적 오류로 거절합니다.
# 외부 PG 인스턴스를 쓰려면 VIBECODER_DB_HOST 를 host:port 로 바꾸고
# compose 의 postgres 서비스를 제거 / 비활성화 하면 됩니다.

# 생성용 패스워드 — 처음 한 번만 의미 있음. 이미 vibe-coder-data/postgres/ 가
# 초기화된 상태에서 이 값을 바꾸면 connect 가 실패합니다 (PG 의 기존 비밀번호 유지).
# 비밀번호를 회전하려면 docker exec 로 ALTER USER 또는 데이터 초기화 후 재부팅.
VIBECODER_DB_PASSWORD=CHANGE_ME_to_a_strong_password

# 아래 값들은 일반적으로 그대로 두어도 됩니다.
VIBECODER_DB_HOST=postgres
VIBECODER_DB_PORT=5432
VIBECODER_DB_NAME=vibecoder
VIBECODER_DB_USER=vibecoder
VIBECODER_DB_MAX_POOL=10
VIBECODER_DB_SSLMODE=disable

# ─── Claude 인증 디렉토리 (옵션) ───────────────────────────────────────────
#
# 기본값(미설정)이면 ${VIBE_DATA_ROOT}/claude 안에서 자체 관리.
# 호스트에서 이미 `claude login` 했고 그 인증을 공유하고 싶으면 아래 주석 해제:
#
# VIBE_CLAUDE_DIR=~/.claude

# ─── Admin 부트스트랩 (선택) ────────────────────────────────────────────────

# 두 값이 모두 설정되어 있고, DB에 admin 사용자가 없으면 첫 부팅 시 자동 생성됩니다.
# 보안상 .env에 plain password를 남기는 점을 인지하고, 부팅 직후 /password에서
# 변경하기를 권장합니다.
#
# 미설정 시 → 브라우저로 http://<IP>:17880/ 또는 /setup 첫 접속 시 setup 화면이 표시됩니다.

# VIBECODER_ADMIN_USERNAME=admin
# VIBECODER_ADMIN_PASSWORD=ChangeMe123

# ─── CORS (v0.12.0+) ───────────────────────────────────────────────────────
#
# 콤마 구분 host 목록 — server.yml 의 cors.allowedHosts 를 덮어쓴다.
# `*` 가 포함되면 anyHost (LAN 격리 환경 기본). 외부 origin 노출 시엔
# 신뢰 origin 만 명시.
#
# 예: VIBECODER_CORS_ALLOWED_HOSTS=https://my-app.example.com,https://staging.example.com,*.dev.example.com
#
# VIBECODER_CORS_ALLOWED_HOSTS=*
# VIBECODER_CORS_ALLOW_CREDENTIALS=false

# ─── SSR Language (v0.77.0+) ──────────────────────────────────────────────
#
# 사용자 별 언어 설정이 없을 때 적용될 fallback.
# 허용 값: en, ko. 기본 en (CLAUDE.md §5 공개 문서 영문 표준).
# 사용자는 Settings → General → Language 에서 본인 언어를 별도로 선택.
#
# VIBECODER_DEFAULT_LANGUAGE=en

# ─── JVM (튜닝) ────────────────────────────────────────────────────────────

# Gradle/Kotlin 컴파일 시 메모리 사용량을 고려해 호스트 RAM의 30~50%를 권장.
# 예: 32GB 머신 → -Xmx8g
JAVA_OPTS=-Xmx2g -XX:+UseG1GC -Dfile.encoding=UTF-8

# ─── 리소스 보호 (권장) ───────────────────────────────────────────────────
#
# Claude/Codex/OpenCode/Gradle/Flutter 는 JVM 밖의 자식 프로세스로 메모리를 크게 쓸 수
# 있습니다. 아래 Docker cgroup hard limit 이 없으면 컨테이너가 호스트 PC 전체 메모리를
# 잠식해 시스템이 멈출 수 있습니다. 운영 PC RAM보다 충분히 낮게 설정하세요.
#
# 예: 16GB PC → 서버 8g, PG 1g / 32GB PC → 서버 16g, PG 2g
VIBECODER_SERVER_MEMORY_LIMIT=8g
VIBECODER_SERVER_MEMORY_SWAP_LIMIT=8g
VIBECODER_SERVER_PIDS_LIMIT=2048
VIBECODER_POSTGRES_MEMORY_LIMIT=1g
VIBECODER_POSTGRES_MEMORY_SWAP_LIMIT=1g
VIBECODER_POSTGRES_PIDS_LIMIT=256

# 앱 내부 soft guard. cgroup 사용률이 soft/hard 임계에 도달하면 새 AI/빌드 작업을
# 보류하고, 가능하면 연결 끊긴 idle TUI 세션을 먼저 종료합니다.
VIBECODER_RESOURCE_GUARD_ENABLED=true
VIBECODER_RESOURCE_MEMORY_SOFT_PERCENT=88
VIBECODER_RESOURCE_MEMORY_HARD_PERCENT=96
VIBECODER_RESOURCE_MIN_FREE_MEMORY_MB=768
VIBECODER_RESOURCE_KILL_IDLE_TUI_ON_PRESSURE=true
VIBECODER_CONSOLE_TUI_IDLE_TIMEOUT_MINUTES=120

# ─── iPhone / macOS agent 설정 (server.yml override) ───────────────────────
# local = MacBook 로컬 설치, ssh = 원격 macOS agent. Linux Docker 단독은 Simulator 실행 불가.
VIBECODER_IOS_AGENT_ENABLED=false
VIBECODER_IOS_AGENT_MODE=local
VIBECODER_IOS_AGENT_HOST=
VIBECODER_IOS_AGENT_PORT=22
VIBECODER_IOS_AGENT_USER=
VIBECODER_IOS_AGENT_WORKSPACE_ROOT=
VIBECODER_IOS_AGENT_XCODE_PATH=auto

# ─── AI provider 설정 (server.yml override, v1.150.0+) ──────────────────────
# Claude/Codex/OpenCode 3 provider. 상세는 /settings 페이지 또는 server.yml.

# OpenCode(GLM, z.ai coding plan) — opencode CLI provider.
# 기본 모델 (provider/model 형식).
# VIBECODER_OPENCODE_MODEL=zai-coding-plan/glm-5.2
# opencode CLI 경로 override (기본: OPENCODE_CMD env → opencode).
# VIBECODER_OPENCODE_CMD=opencode
# OPENCODE_CONFIG_HOME override (기본: ~/.config/opencode).
# VIBECODER_OPENCODE_CONFIG_HOME=default
# z.ai coding plan 강제 모드 (true 면 OpenCode provider 를 z.ai 구독 경로로 고정).
# VIBECODER_ZAI_ENFORCE_CODING_PLAN=false
