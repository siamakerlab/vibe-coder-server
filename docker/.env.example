# vibe-coder Docker 환경설정 템플릿.
# 사용:
#   cp docker/.env.example docker/.env
#   값을 수정한 뒤 `docker compose -f docker/compose.yml --env-file docker/.env up -d`
#
# v0.14.0 — PostgreSQL 컨테이너 추가. **VIBECODER_DB_PASSWORD 반드시 변경 후 사용.**

# ─── 이미지 / 컨테이너 ──────────────────────────────────────────────────────

# Docker Hub에서 pull 시 사용할 태그. 로컬 빌드 시에는 무관.
VIBECODER_IMAGE=siamakerlab/vibe-coder-server:latest

# PostgreSQL 이미지 (v0.14.0+). 직접 변경하지 않는 한 그대로.
VIBECODER_POSTGRES_IMAGE=postgres:17-alpine

# 호스트 UID/GID. `id -u` / `id -g` 결과를 넣으세요. 워크스페이스 권한 매칭용.
PUID=1000
PGID=1000

TZ=Asia/Seoul

# ─── 네트워크 ──────────────────────────────────────────────────────────────

# 호스트에 노출할 포트. LAN의 다른 기기에서 http://<PC IP>:이포트/admin 으로 접속.
VIBE_PORT=17880

# ─── 데이터 디렉토리 (v0.7.0 통합 구조) ────────────────────────────────────
#
# 모든 영구 데이터는 이 한 디렉토리 안에 모입니다. 이 디렉토리만 백업하면
# 워크스페이스 / PostgreSQL / Android SDK / Gradle 캐시 / MCP / Playwright /
# 설정 까지 전부 보존됩니다. 이미지 업그레이드 / 컨테이너 재생성 시에도 안전.
#
# 컴퓨터 이전 (postgres 컨테이너는 정지한 채로 백업 권장):
#   docker compose stop postgres   # 데이터 일관성 보장
#   tar czf vibe-coder-data.tar.gz vibe-coder-data/
#   docker compose up -d
#
# 디렉토리 구조 (compose 가 자동 생성):
#   ./vibe-coder-data/
#     ├── workspace/      ← 프로젝트 소스 / APK
#     ├── postgres/       ← PostgreSQL 데이터 (v0.14.0+)
#     ├── server/         ← 로그 / 빌드 메타
#     ├── dev-tools/      ← Android SDK / Gradle / MCP / Playwright / 설정
#     └── claude/         ← Claude OAuth 자격증명 / MCP 등록 정보
#
VIBE_DATA_ROOT=./vibe-coder-data

# ─── PostgreSQL (v0.14.0+) ─────────────────────────────────────────────────
#
# **VIBECODER_DB_PASSWORD 는 반드시 강력한 값으로 변경하세요.**
# compose 가 빈 값에서 부팅 시도하면 명시적 오류로 거절합니다.
# 외부 PG 인스턴스를 쓰려면 VIBECODER_DB_HOST 를 host:port 로 바꾸고
# compose 의 postgres 서비스를 제거 / 비활성화 하면 됩니다.

# 생성용 패스워드 — 처음 한 번만 의미 있음. 이미 vibe-coder-data/postgres/ 가
# 초기화된 상태에서 이 값을 바꾸면 connect 가 실패합니다 (PG 의 기존 비밀번호 유지).
# 비밀번호를 회전하려면 docker exec 로 ALTER USER 또는 데이터 초기화 후 재부팅.
VIBECODER_DB_PASSWORD=CHANGE_ME_to_a_strong_password

# 아래 값들은 일반적으로 그대로 두어도 됩니다.
VIBECODER_DB_HOST=postgres
VIBECODER_DB_PORT=5432
VIBECODER_DB_NAME=vibecoder
VIBECODER_DB_USER=vibecoder
VIBECODER_DB_MAX_POOL=10
VIBECODER_DB_SSLMODE=disable

# ─── Claude 인증 디렉토리 (옵션) ───────────────────────────────────────────
#
# 기본값(미설정)이면 ${VIBE_DATA_ROOT}/claude 안에서 자체 관리.
# 호스트에서 이미 `claude login` 했고 그 인증을 공유하고 싶으면 아래 주석 해제:
#
# VIBE_CLAUDE_DIR=~/.claude

# ─── Admin 부트스트랩 (선택) ────────────────────────────────────────────────

# 두 값이 모두 설정되어 있고, DB에 admin 사용자가 없으면 첫 부팅 시 자동 생성됩니다.
# 보안상 .env에 plain password를 남기는 점을 인지하고, 부팅 직후 /admin/password에서
# 변경하기를 권장합니다.
#
# 미설정 시 → 브라우저로 http://<IP>:17880/admin 첫 접속 시 setup 화면이 표시됩니다.

# VIBECODER_ADMIN_USERNAME=admin
# VIBECODER_ADMIN_PASSWORD=ChangeMe123

# ─── CORS (v0.12.0+) ───────────────────────────────────────────────────────
#
# 콤마 구분 host 목록 — server.yml 의 cors.allowedHosts 를 덮어쓴다.
# `*` 가 포함되면 anyHost (LAN 격리 환경 기본). 외부 origin 노출 시엔
# 신뢰 origin 만 명시.
#
# 예: VIBECODER_CORS_ALLOWED_HOSTS=https://my-app.example.com,https://staging.example.com,*.dev.example.com
#
# VIBECODER_CORS_ALLOWED_HOSTS=*
# VIBECODER_CORS_ALLOW_CREDENTIALS=false

# ─── SSR Language (v0.77.0+) ──────────────────────────────────────────────
#
# 사용자 별 언어 설정이 없을 때 적용될 fallback.
# 허용 값: en, ko. 기본 en (CLAUDE.md §5 공개 문서 영문 표준).
# 사용자는 Settings → General → Language 에서 본인 언어를 별도로 선택.
#
# VIBECODER_DEFAULT_LANGUAGE=en

# ─── JVM (튜닝) ────────────────────────────────────────────────────────────

# Gradle/Kotlin 컴파일 시 메모리 사용량을 고려해 호스트 RAM의 30~50%를 권장.
# 예: 32GB 머신 → -Xmx8g
JAVA_OPTS=-Xmx2g -XX:+UseG1GC -Dfile.encoding=UTF-8
